# Supabase
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...

# Telegram токен — ТОЛЬКО в Supabase Secrets, НИКОГДА сюда:
#   supabase secrets set TELEGRAM_BOT_TOKEN=ВАШ_ТОКЕН
#   supabase secrets set TELEGRAM_CHAT_ID=ВАШ_CHAT_ID
#
# INTERNAL_SECRET больше не нужен — авторизация идёт через
# JWT подпись Supabase (SUPABASE_JWT_SECRET доступен в Edge
# Functions автоматически, задавать вручную не нужно).
